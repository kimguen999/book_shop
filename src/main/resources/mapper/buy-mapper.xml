<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 해당 파일에 모든 쿼리문을 작성 -->
<!-- namespace에는 xml파일과 연결할 Mapper interface 파일명을 패키지를 포함하여 적어주세요 -->
<mapper namespace="com.green.book_shop_t.buy.mapper.BuyMapper">
	<resultMap id="buy" type="com.green.book_shop_t.buy.dto.ShopBuyDTO">
        <id column="BUY_NUM"           property="buyNum"/>
        <result column="BUY_PRICE"     property="buyPrice"/>
        <result column="MEM_EMAIL"     property="memEmail"/>
        <result column="BUY_DATE"      property="buyDate"/>
    </resultMap>

    <resultMap id="buyDetail" type="com.green.book_shop_t.buy.dto.BuyDetailDTO">
        <id column="BUY_DETAIL"       property="buyDetail"/>
        <result column="BOOK_NUM"     property="bookNum"/>
        <result column="BUY_CNT"      property="buyCnt"/>
        <result column="BUY_NUM"      property="buyNum"/>
    </resultMap>

    <!--구매내역 목록 조회 (도서 정보 포함)-->
    <resultMap id="buyList" type="com.green.book_shop_t.buy.dto.BuyListDTO">
        <id   column="BUY_NUM"    property="buyNum"/>
        <result column="BUY_PRICE" property="buyPrice"/>
        <result column="BUY_DATE"  property="buyDate"/>
        <collection property="detailList" ofType="com.green.book_shop_t.buy.dto.BuyDetailInfoDTO">
            <id   column="BOOK_NUM"          property="bookNum"/>
            <result column="BUY_CNT"         property="buyCnt"/>
            <result column="BOOK_TITLE"      property="bookTitle"/>
            <result column="BOOK_PRICE"      property="bookPrice"/>
            <result column="UPLOAD_FILE_NAME" property="uploadFileName"/>
        </collection>
    </resultMap>



    <!--도서 구매 등록-->
    <insert id="insertBuy" useGeneratedKeys="true" keyProperty="buyNum">
        <!--useGeneratedKeys는 Auto Increment 된 키를 insert시 사용하겠다-->
        <!--keyProperty는 이 쿼리의 빈값을 채우기 위해 가져온 객체(ShopBuyDTO)의 buyNum 변수에 생성된 key를 넣어주겠다는 의미-->
        INSERT INTO SHOP_BUY(
            BUY_PRICE
            , MEM_EMAIL
        ) VALUES (
            #{buyPrice}
            , #{memEmail}
        )
    </insert>

    <!--도서 구매 등록(상세)-->
    <insert id="insertBuyDetail">
        INSERT INTO BUY_DETAIL (
            BOOK_NUM
            , BUY_CNT
            , BUY_NUM
        ) VALUES
            <!--#{bookNum}     ShopBuyDTO.getBookNum-->
            <!--#{detailList[0].bookNum}     ShopBuyDTO.getDetailList().getBookNum-->
            <foreach collection="detailList" item="detail" separator=",">
                <!--collection은 dto의 변수명과 같아야함. 그래야 getDetailList로 알아먹는다.-->
                (
                    #{detail.bookNum}
                <!--하나를 detail이라 지정한 배열 안에 bookNum과 buyCnt가 있기 때문에, detail.bookNum 이런 식으로 적어야한다.-->
                    , #{detail.buyCnt}
                    , #{buyNum}
                )

            </foreach>

    </insert>




    <select id="selectBuyList" resultMap="buyList">
        SELECT
            SB.BUY_NUM
            , SB.BUY_PRICE
            , SB.BUY_DATE
            , BD.BOOK_NUM
            , BD.BUY_CNT
            , B.BOOK_TITLE
            , B.BOOK_PRICE
            , I.UPLOAD_FILE_NAME
        FROM
            SHOP_BUY SB
            INNER JOIN BUY_DETAIL BD ON SB.BUY_NUM = BD.BUY_NUM
            INNER JOIN SHOP_BOOK B   ON BD.BOOK_NUM = B.BOOK_NUM
            LEFT JOIN BOOK_IMG I     ON BD.BOOK_NUM = I.BOOK_NUM AND I.IS_MAIN = 'Y'
        WHERE
            SB.MEM_EMAIL = #{memEmail}
        ORDER BY
            SB.BUY_DATE DESC
    </select>

    <!--오늘과 이 달의 주문건수 및 매출금액 조회 쿼리-->
    <!--MariaDB 함수로 수정: TO_CHAR→DATE_FORMAT, NVL→IFNULL-->
    <select id="selectSaleInfo" resultType="map">
        SELECT
        (
            SELECT COUNT(BUY_NUM)
            FROM SHOP_BUY
            WHERE DATE(BUY_DATE) = CURRENT_DATE()
        ) AS saleCntToday,
        (
            SELECT COUNT(BUY_NUM)
            FROM SHOP_BUY
            WHERE DATE(BUY_DATE)
            BETWEEN DATE_FORMAT(CURRENT_DATE(), '%Y-%m-01')
            AND CURRENT_DATE()
        ) AS saleCntMonth,
        (
            SELECT IFNULL(SUM(BUY_PRICE), 0)
            FROM SHOP_BUY
            WHERE DATE(BUY_DATE) = CURRENT_DATE()
        ) AS saleToday,
        (
            SELECT IFNULL(SUM(BUY_PRICE), 0)
            FROM SHOP_BUY
            WHERE DATE(BUY_DATE)
            BETWEEN DATE_FORMAT(CURRENT_DATE(), '%Y-%m-01')
            AND CURRENT_DATE()
        ) AS saleMonth
    </select>





    <resultMap id="topBuyer" type="com.green.book_shop_t.buy.dto.TopBuyerDTO">
        <result column="MEM_EMAIL"              property="memEmail" />
        <result column="SALE_CNT_PER_MEMBER"    property="saleCntPerMember" />
        <result column="SALE_PER_MEMBER"        property="salePerMember" />
    </resultMap>

    <!--구매자 구매랭킹 조회 쿼리-->
    <select id="selectTopBuyer" resultMap="topBuyer">  <!--한 행에 대한 자료형-->
        SELECT MEM_EMAIL
            , COUNT(BUY_NUM) SALE_CNT_PER_MEMBER
            , SUM(BUY_PRICE) SALE_PER_MEMBER
<!--            , ROW_NUMBER() OVER (ORDER BY SALE_PER_MEMBER DESC)-->
        FROM SHOP_BUY
        GROUP BY MEM_EMAIL
        ORDER BY SALE_PER_MEMBER DESC
        LIMIT 5
    </select>






    <resultMap id="topBook" type="com.green.book_shop_t.buy.dto.TopBookDTO">
        <result column="BOOK_NUM"              property="bookNum" />
        <result column="TOTAL_BUY_CNT"    property="totalBuyCnt" />
        <result column="BOOK_TITLE"        property="bookTitle" />
        <result column="AUTHOR"        property="author" />
    </resultMap>

    <!--인서 도서 랭킹-->
    <select id="selectTopBook" resultMap="topBook">
        SELECT D.BOOK_NUM, SUM(BUY_CNT) TOTAL_BUY_CNT, BOOK_TITLE, AUTHOR
        FROM BUY_DETAIL D, SHOP_BOOK B
        WHERE D.BOOK_NUM = B.BOOK_NUM
        GROUP BY D.BOOK_NUM
        ORDER BY TOTAL_BUY_CNT DESC, BOOK_TITLE ASC
        LIMIT  5
    </select>







    <!--최근 10일 차트 데이터 조회-->

    <select id="selectSale10" resultType="map">

        <foreach collection="dayList" item="day" separator="UNION ALL" >
            SELECT ADDDATE(CURRENT_DATE(), -#{day}) AS day
            , (SELECT NVL(SUM(BUY_PRICE), 0)
            FROM SHOP_BUY
            WHERE DATE(BUY_DATE) = ADDDATE(CURRENT_DATE(), -#{day})) AS sale
        </foreach>



    </select>



</mapper>































